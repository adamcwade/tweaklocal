# Copy to .env.local and fill in. Real values live in the Vercel dashboard.
# .env.local is gitignored; this file is not — keep it placeholders only.

# Neon connection string (Project → Connection Details → pooled).
DATABASE_URL="postgresql://user:password@host.neon.tech/neondb?sslmode=require"

# Bearer token for GET /api/stats. Generate:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
STATS_TOKEN=""

# Vercel sends this to /api/prune as `Authorization: Bearer …` when set.
CRON_SECRET=""
